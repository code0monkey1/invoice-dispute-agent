GROQ_API_KEY=your_groq_api_key
TAVILY_API_KEY=your_tavily_api_key

# Google OAuth (from Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
GOOGLE_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-notifications

# Telegram Bot (from @BotFather)
# Each user binds their own chat via the in-app "Connect Telegram" flow —
# no shared TELEGRAM_CHAT_ID anymore.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
# Random secret you set via setWebhook; echoed in the x-telegram-bot-api-secret-token header.
TELEGRAM_WEBHOOK_SECRET=

# CORS — comma-separated origins that may send credentials. Required for the
# guest_session cookie when frontend and backend live on different origins.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase (Project Settings > API — use the service_role key)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_INVOICE_FILE_BUCKET=invoice-files

# Security
SECRET_KEY=generate-a-random-32-byte-key-here

# Postgres checkpointer (Supabase transaction pooler URL — required for Vercel)
# Get from: Supabase Dashboard > Project Settings > Database > Transaction pooler
# Format: postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=
