{
  "buildCommand": "npm install --prefix frontend && npm run build --prefix frontend",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@6.29.0",
      "maxDuration": 60,
      "includeFiles": "frontend/dist/**"
    }
  }
}
